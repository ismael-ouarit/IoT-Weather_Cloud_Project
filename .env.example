# BigQuery Credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
GCP_PROJECT_ID=your-project-id
BQ_DATASET_NAME=weather_station

# External APIs
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
OPENAI_API_KEY=your_openai_api_key   # If using OpenAI for TTS/STT

# Deployment / Location config
ZIP_CODE=10001
COUNTRY_CODE=US
LATITUDE=40.7128
LONGITUDE=-74.0060

# M5Stack WiFi Details (Initial - user can change via UI)
WIFI_SSID=iot-unil
WIFI_PASSWORD=your_wifi_password

# Networking
API_ENDPOINT=https://your-flask-api.run.app
