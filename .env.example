# ── Google Cloud ────────────────────────────────────────────────
# Path to your service account JSON (local development only).
# Cloud Run uses the runtime service account automatically, so this
# variable is NOT set on the deployed services.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# BigQuery dataset name (must exist in the GCP project tied to your
# service account). Tables expected: sensor_data, weather_data.
BQ_DATASET_NAME=weather_station

# ── External APIs ───────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
GEMINI_API_KEY=your_gemini_api_key

# ── Optional: default location fallback ─────────────────────────
# Only used by the /voice_answer debug endpoint when no lat/lon is
# passed in the request. The M5Stack device always sends its own
# coordinates, so this rarely matters in production.
LATITUDE=46.5197
LONGITUDE=6.6323
